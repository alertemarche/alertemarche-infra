# ============================================
# AlerteMarché — Modèle d'environnement PRODUCTION
# Copiez ce fichier en `.env` et complétez les valeurs.
# ============================================

# Application
APP_NAME=AlerteMarche
APP_ENV=production
APP_KEY=            # générer : docker compose exec app php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://alertemarche.com
APP_LOCALE=fr

# Base de données PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=alertemarche
DB_USERNAME=alertemarche
DB_PASSWORD=change_me

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Brevo
BREVO_API_KEY=
BREVO_SENDER_EMAIL=info@alertemarche.com
BREVO_SENDER_NAME=AlerteMarché

# WhatsApp Business Platform
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# KKPays
KKPAYS_API_KEY=
KKPAYS_SECRET=
KKPAYS_MERCHANT_ID=
KKPAYS_BASE_URL=https://api.kkpays.com

# Métier
SUPPORTED_COUNTRIES=BJ,TG,CI
PRICE_ARTISAN=10000
PRICE_PRESTATAIRE=50000
PRICE_ADMIN_ONG=150000
LAUNCH_DISCOUNT_PERCENT=50
FREEMIUM_ALERTS=5

# Robots de collecte
SCRAPERS_API_TOKEN=
BENIN_SOURCE_URL=https://armp.bj
TOGO_SOURCE_URL=https://armp.tg
CI_SOURCE_URL=https://www.anrmp.ci
SCRAPE_INTERVAL_MINUTES=120
LOG_LEVEL=INFO

# Admin (seed)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Mail
MAIL_MAILER=log
MAIL_FROM_ADDRESS=info@alertemarche.com
MAIL_FROM_NAME=AlerteMarché

# Google Analytics
GA4_MEASUREMENT_ID=G-RRXKSCN05J
